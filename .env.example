# Supabase 프로젝트 설정 (Project Settings → API)에서 복사하세요.
# anon/public key는 공개 가능한 키입니다. service_role 키는 절대 여기 넣지 마세요.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 결제 (PART 2 ④). 두 값 모두 "공개용" 클라이언트 키이며 시크릿 키가 아닙니다.
# 시크릿 키(TOSS_SECRET_KEY, PAYPAL_CLIENT_SECRET)는 여기 넣지 말고
# `supabase secrets set`으로 Edge Function 쪽에만 설정하세요.
VITE_TOSS_CLIENT_KEY=test_ck_your_toss_client_key
VITE_PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
